{
  "manifest_version": 3,
  "name": "ReadingList Enhancer",
  "version": "0.1.1",
  "description": "Enhance Chrome Reading List with side-panel search, filters, local tags, and JSON/URL import/export.",
  "key": "",
  "minimum_chrome_version": "120",
  "permissions": [
    "readingList",
    "sidePanel",
    "contextMenus",
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel/index.html"
  },
  "action": {
    "default_title": "Open ReadingList Enhancer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
